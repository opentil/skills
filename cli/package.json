{
  "name": "@opentil/cli",
  "version": "1.33.0",
  "description": "Universal skill installer for OpenTIL",
  "type": "module",
  "bin": {
    "opentil": "./dist/index.js"
  },
  "files": [
    "dist",
    "templates"
  ],
  "scripts": {
    "prebuild": "node scripts/copy-skill.js",
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@clack/prompts": "^0.10.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/opentil/opentil-skills.git",
    "directory": "cli"
  },
  "keywords": [
    "opentil",
    "til",
    "skill",
    "installer",
    "claude-code",
    "cursor",
    "codex",
    "opencode",
    "github-copilot",
    "windsurf",
    "antigravity",
    "gemini-cli",
    "openclaw",
    "ai-agent"
  ]
}
